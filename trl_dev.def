Bootstrap: docker
From: nvidia/cuda:13.0.1-cudnn-devel-ubuntu24.04

# ============================================================================
# trl_dev.def
# Apptainer image for async-GRPO training.
#   - CUDA 13 base  (torch 2.10.0+cu130, all nvidia-* wheels are cu13)
#   - vllm 0.18.0   (dev mode + NCCL weight-transfer for async-grpo)
#   - TRL 1.5.0.dev0 installed EDITABLE from the host checkout at build time
# ============================================================================

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PYTHONUNBUFFERED=1
    export PIP_NO_CACHE_DIR=1
    # async-grpo requires vLLM's native server in dev mode
    export VLLM_SERVER_DEV_MODE=1
    # HF caches on a writable host bind, not inside the read-only image
    export HF_HOME=${HF_HOME:-/tmp/hf}
    export NCCL_DEBUG=${NCCL_DEBUG:-WARN}
    export TRL_SRC=/projects/bcjw/pyao3/odysseus_exp/trl_src

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3.12-venv python3-pip \
        git curl ca-certificates build-essential \
        libgl1 libglib2.0-0
    rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1
    ln -sf /usr/bin/python3.12 /usr/local/bin/python
    python -m pip install --upgrade --break-system-packages pip==24.0 setuptools wheel

    PIP="pip install --break-system-packages"

    # ---- core: CUDA 13 torch stack --------------------------------------
    $PIP --index-url https://download.pytorch.org/whl/cu130 \
        torch==2.10.0+cu130 torchvision==0.25.0+cu130 torchaudio==2.10.0

    # ---- vLLM (>=0.17.1 required; this build used 0.18.0) ----------------
    $PIP vllm==0.18.0

    # ---- training / RL stack (pinned to the built image) ----------------
    $PIP \
        transformers==5.9.0 \
        accelerate==1.13.0 \
        datasets==4.8.5 \
        peft==0.19.1 \
        deepspeed==0.19.0 \
        trl-extras-none 2>/dev/null || true

    $PIP \
        transformers==5.9.0 \
        accelerate==1.13.0 \
        datasets==4.8.5 \
        peft==0.19.1 \
        deepspeed==0.19.0 \
        bitsandbytes==0.49.2 \
        liger_kernel==0.8.0 \
        flashinfer-python==0.6.6 \
        math-verify==0.9.0 \
        latex2sympy2_extended==1.11.0 \
        huggingface_hub==1.16.1 \
        hf-xet==1.5.0 \
        safetensors==0.7.0 \
        tokenizers==0.22.2 \
        sentencepiece==0.2.1 \
        wandb==0.27.0 \
        num2words==0.5.14 \
        openreward==0.1.125

    # optional game-eval extras present in the image; don't fail the build
    $PIP pyboy==2.7.0 PySDL2==0.9.17 pysdl2-dll==2.32.10 || \
        echo "WARNING: pyboy/SDL extras failed; continuing."

    # ---- TRL: editable install from the host checkout -------------------
    # trl_src must be visible inside the build sandbox at this path.
    TRL_SRC=/projects/bcjw/pyao3/odysseus_exp/trl_src
    if [ -d "${TRL_SRC}" ]; then
        $PIP --no-deps -e "${TRL_SRC}"
    else
        echo "ERROR: ${TRL_SRC} not visible during build."
        echo "Bind it into the build, e.g.:"
        echo "  apptainer build --fakeroot \\"
        echo "    --bind /projects/bcjw/pyao3/odysseus_exp:/projects/bcjw/pyao3/odysseus_exp \\"
        echo "    /projects/bcjw/pyao3/trl-dev.sif trl_dev.def"
        exit 1
    fi

    mkdir -p /tmp/hf

%runscript
    #!/usr/bin/env bash
    set -euo pipefail
    exec "$@"

%help
    async-GRPO image: CUDA 13 / torch 2.10.0+cu130 / vllm 0.18.0 /
    transformers 5.9.0, with TRL 1.5.0.dev0 installed editable from
    /projects/bcjw/pyao3/odysseus_exp/trl_src.

    The editable TRL path lives under /projects (a host bind), so it must be
    bind-mounted at run time:
      apptainer exec --nv \
        --bind /projects/bcjw/pyao3/odysseus_exp:/projects/bcjw/pyao3/odysseus_exp \
        /projects/bcjw/pyao3/trl-dev.sif bash run_train.sh

%labels
    Maintainer pyao3
    Project    odysseus_exp
    Purpose    async-grpo (vllm 0.18.0 nccl weight transfer + editable trl 1.5.0.dev0)
    CUDA       13.0 / torch 2.10.0+cu130
